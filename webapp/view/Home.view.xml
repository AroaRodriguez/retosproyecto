<mvc:View 
    controllerName="retosproyecto.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
    displayBlock="true">
    <!-- Filtros:-->
        <fb:FilterBar id="filterBar" header="{i18n>busqueda}" search=".buscar" showClearOnFB= "true"  clear=".limpiarFiltro"> <!--Definido botón GO, SAP lo hace, dispara la logica con el filterBar-->
                <fb:filterGroupItems>
                    
                    <fb:FilterGroupItem id="filtrarSolicitud" name="Solicitud" label="{i18n>solicitud}" groupName="G1" visibleInFilterBar="true"> <!--visibilidad de la barra visibleInFilterBar-->
                        <fb:control>
                            <Input id="inSolicitud" placeholder="número" /> <!--placeholder = igual a Android hinit-->
                        </fb:control>
                    </fb:FilterGroupItem>

                    <fb:FilterGroupItem id="filtrarTipologia" name="Tipologia" label="{i18n>tipologia}" groupName="G1" visibleInFilterBar="true">
                        <fb:control>
                             <Input id="inTipologia" showValueHelp="true" valueHelpRequest=".ayudaRequerida" placeholder="tipo"  /> 
                        </fb:control>
                    </fb:FilterGroupItem>

                    <fb:FilterGroupItem id="filtrarCategorizacion" name="Categorizacion" label="{i18n>categoria}" groupName="G1" visibleInFilterBar="true">
                        <fb:control>
                            <ComboBox id="cbCategorizacion" items="{filtradoModel>/CategoriasSet}"> <!-- Combo box de categorización-->
                                <core:Item id="categoryFilter" key="{filtradoModel>categoria}" text="{filtradoModel>categoria}"/>
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>

                </fb:filterGroupItems>
            </fb:FilterBar>
    <!-- Tabla:-->        
    <Table id="idTable"
        items="{listModel>/SolicitudesSet}"
        mode="MultiSelect"
        growing="true"
        growingThreshold="10"
        sticky="HeaderToolbar,ColumnHeaders"
        class="sapUiResponsiveMargin"
        width="auto">
        
        <headerToolbar>
            <OverflowToolbar id="toolbar">
                <Title id="tituloLista" text="{i18n>listaSolicitudes}" titleStyle="H4" />
                <ToolbarSpacer id="toolbarspacer" />
                <!-- Crear botones crear, borrar-->
                <!--Boton crear-->
                <Button id="btnCreate"
                        icon="sap-icon://add"
                        text="{i18n>crear}"
                        type="Emphasized" 
                        press=".crear" />
                <!--Boton eliminar-->
                <Button id="btnDelete" 
                         icon="sap-icon://delete" 
                         text="{i18n>eliminar}" 
                        type="Transparent" 
                        press=".eliminar" />
                <!--Boton editar-->       
                <Button id="btneditar" 
                         icon="sap-icon://edit" 
                         text="{i18n>editar}" 
                        type="Transparent" 
                        press=".editar" />        

            </OverflowToolbar>
        </headerToolbar>

        <columns>
            <Column id="columnaNum" width="8rem">
                <Text id="txtColSol" text="{i18n>solicitud}" />
            </Column>
            <Column id="columnaTipo" minScreenWidth="Tablet" demandPopin="true">
                <Text id="txtColTipo" text="{i18n>tipologia}" /> <!-- preguntar si se pueden aprovechar los titulos.-->
            </Column>
            <Column id="columnaCateg" minScreenWidth="Tablet" demandPopin="true">
                <Text id="txtColCateg" text="{i18n>categoria}" />
            </Column>
            <Column id="estado" hAlign="Center">
                <Text id="txtColestado" text="{i18n>estado}" />
            </Column>
            <Column id="precio" hAlign="Center">
                <Text id="txtColprecio" text="{i18n>precio}" />
            </Column>
        </columns>

        <items>
            <ColumnListItem id="listaColumna" vAlign="Middle" type="Navigation" press=".onItemPress">
                <cells>
                    <Text id="id2" text="{listModel>id}" />
                    <Text id="tipo2" text="{listModel>tipologia}" />
                    <Text id="categoria2" text="{listModel>categoria}" />
                    <ObjectStatus id="objectEstado"
                        text="{listModel>estado}"
                        state="{path: 'listModel>estado', formatter: '.formatState'}" /> <!--Creada función lógica del estado-->
                    <ObjectNumber id="objectNumero"
                        number="{listModel>precio}"
                        unit="EUR"
                        state="Information" />    
                </cells>
            </ColumnListItem>
        </items>
    </Table>
</mvc:View>