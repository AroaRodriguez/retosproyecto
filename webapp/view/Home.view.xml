<mvc:View 
    controllerName="retosproyecto.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
    displayBlock="true">
    <!-- Filter:-->
        <fb:FilterBar id="filterBar" header="{i18n>busqueda}" search=".searchMethod" showClearOnFB= "true"  clear=".cleanFilter"> <!--Definido botón GO, SAP lo hace, dispara la logica con el filterBar-->
                <fb:filterGroupItems>
                    
                    <fb:FilterGroupItem id="RequestFilter" name="Request" label="{i18n>request}" groupName="G1" visibleInFilterBar="true"> <!--visibilidad de la barra visibleInFilterBar-->
                        <fb:control>
                            <Input id="inRequest" placeholder="número" /> <!--placeholder = same to Android hinit-->
                        </fb:control>
                    </fb:FilterGroupItem>

                    <fb:FilterGroupItem id="TipologyFilter" name="Tipology" label="{i18n>typology}" groupName="G1" visibleInFilterBar="true">
                        <fb:control>
                             <Input id="inTypology" showValueHelp="true" valueHelpRequest=".HelpRequest" placeholder="tipo"  /> 
                        </fb:control>
                    </fb:FilterGroupItem>
<!--Falta ingles-->
                    <fb:FilterGroupItem id="CategoryFilter" name="Category" label="{i18n>category}" groupName="G1" visibleInFilterBar="true">
                        <fb:control>
                            <ComboBox id="cbCategorizacion" items="{filtradoModel>/CategoriasSet}"> <!-- Combo box de categorización-->
                                <core:Item id="categoryFilter" key="{filtradoModel>categoria}" text="{filtradoModel>categoria}"/>
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>

                </fb:filterGroupItems>
            </fb:FilterBar>
    <!-- Table:-->        
    <Table id="idTable"
        items="{listModel>/SolicitudesSet}"
        mode="MultiSelect"
        growing="true"
        growingThreshold="10"
        sticky="HeaderToolbar,ColumnHeaders"
        class="sapUiResponsiveMargin"
        width="auto">
        
        <headerToolbar>
            <OverflowToolbar id="toolbar">
                <Title id="titleList" text="{i18n>requestList}" titleStyle="H4" />
                <ToolbarSpacer id="toolbarspacer" />
                <!-- Button CRUD-->
                <!--Button create-->
                <Button id="btnCreate"
                        icon="sap-icon://add"
                        text="{i18n>createName}"
                        type="Emphasized" 
                        press=".create" />
                <!--Button delete-->
                <Button id="btnDelete" 
                         icon="sap-icon://delete" 
                         text="{i18n>deleteName}" 
                        type="Transparent" 
                        press=".delete" />
                <!--Button edit-->       
                <Button id="btneditar" 
                         icon="sap-icon://edit" 
                         text="{i18n>editName}" 
                        type="Transparent" 
                        press=".edit" />        

            </OverflowToolbar>
        </headerToolbar>
        <columns>
            <Column id="columnNum" width="8rem">
                <Text id="txtColSol" text="{i18n>request}" />
            </Column>
            <Column id="columnType" minScreenWidth="Tablet" demandPopin="true">
                <Text id="txtColTipo" text="{i18n>typology}" /> 
            </Column>
            <Column id="columnCateg" minScreenWidth="Tablet" demandPopin="true">
                <Text id="txtColCateg" text="{i18n>category}" />
            </Column>
            <Column id="columnStatus" hAlign="Center">
                <Text id="txtColestado" text="{i18n>status}" />
            </Column>
            <Column id="columnPrice" hAlign="Center">
                <Text id="txtColprecio" text="{i18n>price}" />
            </Column>
        </columns>
        <!--Get items model-->
        <items>
            <ColumnListItem id="columnList" vAlign="Middle" type="Navigation" press=".onItemPress">
                <cells>
                    <Text id="id2" text="{listModel>id}" />
                    <Text id="tipo2" text="{listModel>tipologia}" />
                    <Text id="categoria2" text="{listModel>categoria}" />
                    <ObjectStatus id="objectEstado"
                        text="{listModel>estado}"
                        state="{path: 'listModel>estado', formatter: '.formatState'}" /> <!--Creada función lógica del estado-->
                    <ObjectNumber id="objectNumero"
                        number="{listModel>precio}"
                        unit="EUR"
                        state="Information" />    
                </cells>
            </ColumnListItem>
        </items>
    </Table>
</mvc:View>