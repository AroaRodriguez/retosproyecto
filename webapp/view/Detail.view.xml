<mvc:View
    controllerName="retosproyecto.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    displayBlock="true">
    
    <Page id="pageDetail"
          title="{i18n>detailTitle}" 
          showNavButton="true"
          navButtonPress=".onNavBack"> 
        <content>
            <f:SimpleForm id="formDetail" 
              editable="false" 
              layout="ResponsiveGridLayout" 
              labelSpanXL="2" labelSpanL="3" labelSpanM="4" labelSpanS="12" 
              emptySpanXL="6" emptySpanL="5" emptySpanM="0" emptySpanS="0">
                
                <f:toolbar>
                    <Toolbar id ="tbDetail">
                        <Title id="titleDetail" text="{i18n>requestDetail}" level="H4" titleStyle="H4" />
                        
                        <ToolbarSpacer id="spacer" />
                        
                        <Button id="btnEditDetail" text="{i18n>edit}" icon="sap-icon://edit" press=".EditDetailInfo" type="Transparent"/>
                    </Toolbar>
                </f:toolbar>

                <f:content>
                    <Label id="requestLbl" text="{i18n>request}" />
                    <Text id="inDetailId" text="{listModel>id}" /> 

                    <Label id="typologyLbl" text="{i18n>typology}" />
                    <Text id="inDetailTypology" text="{listModel>tipologia}" />

                    <Label id="categoryLbl" text="{i18n>category}" />
                    <Text id="inDetailCategory" text="{listModel>categoria}" />

                    <Label id="statusLbl" text="{i18n>status}" />
                    <ObjectStatus id="inDetailStatus" 
                                  text="{listModel>estado}" 
                                  state="{path: 'listModel>estado', formatter: '.formatter.formatState'}" />
                    
                    <Label id="priceLbl" text="{i18n>price}" />
                    <ObjectNumber id="inDetailPrice" 
                                  number="{path: 'listModel>precio', formatter: '.formatter.formatPrice' }" 
                                  unit="EUR"/>
                </f:content>
            </f:SimpleForm>
        </content>
    </Page>
</mvc:View>