<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <SelectDialog id="selecionar"
        title="{i18n>selecciona}"
        search=".onValueHelpSearch"
        confirm=".onValueHelpConfirm"
        cancel=".onValueHelpClose"
        items="{TipologiasSet}"> 
        <StandardListItem id="estandarlist"
            title="{tipologia}"
            description="{id}"
            type ="Active" />
    </SelectDialog>
</core:FragmentDefinition>