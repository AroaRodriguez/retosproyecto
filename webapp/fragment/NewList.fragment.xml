<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <Dialog id="newEntryDialog" title="{i18n>newRequest}">
        <content>
            <f:SimpleForm id="formularioSimple" editable="true" layout="ResponsiveGridLayout">
                <f:content>
                    <Label id="newRequest" text="{i18n>request}" required="true" /> <!--Obligatory input-->
                    <Input id="newId" placeholder="Ej: 1005" required="true" liveChange=".validationFormulary" />

                    <Label id="newType" text="{i18n>typology}" />
                    <Input id="newTypology" liveChange=".validationFormulary" />

                    <Label id="newCat" text="{i18n>category}" />
                    <ComboBox id="newCategory">
                        <core:Item id="newaction" key="Acción de Marketing" text="{i18n>accion}" />
                        <core:Item id="newSamples" key="Muestras Comerciales" text="{i18n>muestras}"/>
                        <core:Item id="newBuys" key="Compras asociadas" text="{i18n>compras}" />
                    </ComboBox>
                    <Label id="newSt" text="{i18n>status}" /> 
                    <ComboBox id="newStatus">
                        <core:Item id="newApproved" key="Aprobado" text="{i18n>approved}" />
                        <core:Item id="newPending" key="Pendiente" text="{i18n>pending}" />
                        <core:Item id="newReject" key="Rechazado" text="{i18n>reject}" />
                    </ComboBox>

                    <Label id="newPre" text="{i18n>price}" required="true" /> <!--Obligatory input-->
                    <Input id="newPrice" type="Number" description="EUR" required="true" liveChange=".validationFormulary" />
                </f:content>
            </f:SimpleForm>
        </content>
        <beginButton>
            <Button id="BtnSave" text="{i18n>save}" type="Accept" press=".newSave" />
        </beginButton>
        <endButton>
            <Button id="BtnCancel" text="{i18n>cancel}" press=".newDialogClose" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>